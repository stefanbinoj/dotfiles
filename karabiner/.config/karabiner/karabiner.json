{
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Change left_control+hjkl to arrow keys (except Raycast, VSCode, Zed, Cursor, cmux, Ghostty, Terminal)",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^com\\.raycast\\.macos$",
                                            "^com\\.microsoft\\.VSCode$",
                                            "^dev\\.zed\\.Zed$",
                                            "^com\\.cursor\\.Cursor$",
                                            "^com\\.cmux\\.cmux$"
                                        ],
                                        "type": "frontmost_application_unless"
                                    }
                                ],
                                "from": {
                                    "key_code": "h",
                                    "modifiers": {
                                        "mandatory": ["left_control"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [{ "key_code": "left_arrow" }],
